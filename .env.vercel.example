# Set these in Vercel Project Settings -> Environment Variables.
#
# Where to find each value in EmailJS dashboard:
# EMAILJS_SERVICE_ID  -> Email Services -> click your service -> Service ID
# EMAILJS_TEMPLATE_ID -> Email Templates -> open template -> Template ID
# EMAILJS_PUBLIC_KEY  -> Account -> API keys -> Public Key
# EMAILJS_PRIVATE_KEY -> Account -> API keys -> Private Key
# ALLOWED_ORIGINS     -> Optional comma-separated list of frontend origins allowed to call /api/contact

EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=public_key_xxxxxxx
EMAILJS_PRIVATE_KEY=private_key_xxxxxxx
ALLOWED_ORIGINS=https://oyelekeseun.vercel.app,https://oluwablin.github.io
